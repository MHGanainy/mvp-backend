# Copy this file to .env.test and fill in the values.
# .env.test is gitignored — never commit real credentials.

# Local Postgres test database (separate from dev DB)
DATABASE_URL=postgresql://postgres:password@localhost:5432/simsbuddy_test

# Use a fixed secret so tokens are reproducible across test runs
JWT_SECRET=test-jwt-secret-for-testing-only

NODE_ENV=test

# Safety flag — must be present to allow tests to truncate the DB.
# This prevents accidental truncation of non-test databases.
TEST_MODE=1

# Leave blank — external services are mocked in tests
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
SMTP_HOST=
SMTP_USER=
SMTP_PASS=
LIVEKIT_SERVICE_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
OPENAI_API_KEY=
GROQ_API_KEY=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=
CHECK_MAIL_API_KEY=
